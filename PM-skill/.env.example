# .env — PM-skill environment variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to your OpenClaw .env and fill in your values.
# The agent refuses to start if TELEGRAM_ALLOWED_GROUP_ID or GOOGLE_SHEET_TAB
# are missing.
# ─────────────────────────────────────────────────────────────────────────────

# ── Telegram ──────────────────────────────────────────────────────────────────

# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# The group chat ID this agent is bound to.
# To find your group ID: add the bot, send a message, then run:
#   curl https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_ALLOWED_GROUP_ID=-your_group_id_here

# ── Google Sheets ──────────────────────────────────────────────────────────────

# Spreadsheet ID from the URL:
#   docs.google.com/spreadsheets/d/<THIS_PART>/edit
GOOGLE_SHEETS_ID=your_spreadsheet_id_here

# Tab name to write tasks into. Created automatically if it doesn't exist.
GOOGLE_SHEET_TAB=Tasks

# Full JSON of the service account key.
# The spreadsheet MUST be shared with this account's email (Editor access).
# Get from: GCP Console → IAM → Service Accounts → Keys → Add Key → JSON
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ── Anthropic ─────────────────────────────────────────────────────────────────

ANTHROPIC_API_KEY=sk-ant-...
